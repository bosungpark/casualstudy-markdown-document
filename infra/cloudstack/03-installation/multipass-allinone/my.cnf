# MySQL 설정 예시 — CloudStack 4.20 단일 노드 학습용
# 위치: /etc/mysql/conf.d/cloudstack.cnf
#
# 변경 후: systemctl restart mysql
#
# 출처: https://docs.cloudstack.apache.org/en/latest/installguide/management-server/_install.html

[mysqld]
# CloudStack 권장 설정
server-id=master-01
innodb_rollback_on_timeout=1
innodb_lock_wait_timeout=600
max_connections=350
log-bin=mysql-bin
binlog-format='ROW'

# 학습용 추가 — 운영 시엔 더 보수적으로
# innodb_buffer_pool_size=512M
# innodb_log_file_size=128M
# wait_timeout=28800
# interactive_timeout=28800

# 기본 charset
character-set-server=utf8mb4
collation-server=utf8mb4_unicode_ci
